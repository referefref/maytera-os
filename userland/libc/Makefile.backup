# Makefile for MayteraOS userland libc

CC = gcc
AR = ar

CFLAGS = -m64 -ffreestanding -fno-builtin -nostdinc -nostdlib          -fno-stack-protector -mno-red-zone -fno-pic -mcmodel=small          -Wall -Wextra -O2          -isystem /usr/lib/gcc/x86_64-linux-gnu/12/include

# Core sources (pthread excluded for now - missing kernel support)
SRCS = string.c stdio.c stdlib.c gui.c compositor_client.c
OBJS = $(SRCS:.c=.o)

all: crt0.o libc.a

libc.a: $(OBJS) setjmp.o syscall.o
	$(AR) rcs $@ $(OBJS) setjmp.o syscall.o

crt0.o: crt0.S
	$(CC) $(CFLAGS) -c $< -o $@

setjmp.o: setjmp.asm
	nasm -f elf64 $< -o $@

syscall.o: syscall.asm
	nasm -f elf64 $< -o $@

%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@

clean:
	rm -f *.o libc.a

.PHONY: all clean
