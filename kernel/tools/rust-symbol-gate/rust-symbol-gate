#!/usr/bin/env python3
"""rust-symbol-gate (#404 / #526)

FAILS THE BUILD when the Rust kernel crate stops exporting a symbol the C side
depends on, or starts exporting one nobody declared.

WHY THIS EXISTS
---------------
`rustkern.rs` grew to 9,566 lines with 83 `#[no_mangle]` exports, edited
concurrently by four agents in two days. A symbol silently vanishing (a bad
merge, a whole-file push over someone else's work, a botched refactor) BUILDS
CLEAN: the archive just gets smaller. Nothing fails. The only thing that ever
caught it was a human remembering to run `nm` by hand, and the near-misses are
recorded in blame.md:

  * a whole-file push that was one command from deleting all six of #502's live
    TLS 1.2 functions, caught only by manually diffing symbol lists;
  * a "clobber" that was really an edit racing a rebuild, where the ONLY tell was
    `nm librustkern.a` and `grep rustkern.rs` disagreeing.

A C caller of a deleted symbol does fail at link time, but only if a caller is
compiled in *on this build*: every function behind a `-DRUST_*` strangler flag
that is currently off, and every export whose C caller is itself conditional,
can disappear with no diagnostic at all. This gate does not rely on a caller
existing.

WHY STRUCTURAL, NOT HEURISTIC (the shape #503's syscall-ptr-lint established)
----------------------------------------------------------------------------
This gate does not parse Rust and does not try to reason about what "should" be
exported. It asks one mechanical question with a checkable answer, against the
BUILD ARTIFACT rather than the source (the source is exactly what lies to you
when another agent is mid-write):

    Does every symbol named in rust-symbols.manifest appear as a defined,
    global TEXT symbol in librustkern.a, and does every export the rustkern
    crate actually emits appear in the manifest?

Missing symbol   = build failure (someone deleted live code).
Undeclared symbol = build failure (the manifest cannot silently rot; a new
                    export must be declared, which is also where you say who
                    owns it).

ANTI-VACUITY
------------
blame.md records ten false PASSes in this session alone, several of them
harnesses that measured nothing and printed green. The checks below are
therefore fail-closed:

  * an empty/unreadable manifest is an ERROR, not "0 symbols, all present";
  * an archive containing no rustkern codegen units at all is an ERROR, not
    "0 exports, nothing undeclared" (this is the case that would otherwise pass
    while measuring literally nothing, e.g. if the crate were renamed);
  * `nm` failing is an ERROR, not a skip.

Exit codes: 0 = manifest and archive agree, 1 = mismatch, 2 = internal error.
"""

import argparse
import re
import subprocess
import sys

# Members of librustkern.a that belong to OUR crate. rustc names staticlib
# members "<libname>.<crate>.<hash>-cgu.N.rcgu.o", so our codegen units are
# "librustkern.rustkern.<hash>-cgu.N.rcgu.o". Everything else in the archive is
# vendored `core` and `compiler_builtins` (415 members today), whose symbols are
# emphatically NOT our FFI surface and must never enter the manifest.
OUR_MEMBER_RE = re.compile(r"^librustkern\.rustkern\.[0-9a-f]+-cgu\.\d+\.rcgu\.o$")

# Rust-mangled names (v0 `_R...` / legacy `_ZN...`). These are compiler-internal
# and their names embed a per-build crate hash, so they change on every source
# edit and can never be pinned in a manifest. The panic-handler shim
# (`_RNvCs...rust_begin_unwind`) is the only one our crate emits today.
MANGLED_RE = re.compile(r"^(_R|_ZN)")


def read_manifest(path):
    """Parse the manifest: one symbol per line, '#' comments, blanks ignored."""
    try:
        with open(path) as fh:
            raw = fh.read()
    except OSError as exc:
        raise SystemExit(f"rust-symbol-gate: ERROR: cannot read manifest {path}: {exc}")

    syms = []
    for lineno, line in enumerate(raw.split("\n"), 1):
        line = line.split("#", 1)[0].strip()
        if not line:
            continue
        if not re.fullmatch(r"[A-Za-z_][A-Za-z0-9_]*", line):
            raise SystemExit(
                f"rust-symbol-gate: ERROR: {path}:{lineno}: not a valid C identifier: {line!r}"
            )
        syms.append(line)

    dupes = sorted({s for s in syms if syms.count(s) > 1})
    if dupes:
        raise SystemExit(
            f"rust-symbol-gate: ERROR: duplicate manifest entries: {', '.join(dupes)}"
        )
    if not syms:
        # Fail closed: an empty manifest would make every check trivially pass.
        raise SystemExit(f"rust-symbol-gate: ERROR: manifest {path} declares no symbols")
    return syms


def nm_archive(nm, archive):
    """Return (all_defined_text, our_exports) from the archive.

    all_defined_text: every defined global text symbol, any member. Used for the
                      MISSING check, so a symbol that moved between codegen units
                      (or even into another member) still counts as present.
    our_exports:      defined global text symbols in OUR crate's codegen units,
                      excluding Rust-mangled internals. This is the FFI surface.
    """
    try:
        out = subprocess.run(
            [nm, "--defined-only", "-g", "-A", archive],
            capture_output=True, text=True, check=True,
        ).stdout
    except FileNotFoundError:
        raise SystemExit(f"rust-symbol-gate: ERROR: {nm} not found")
    except subprocess.CalledProcessError as exc:
        raise SystemExit(
            f"rust-symbol-gate: ERROR: {nm} failed on {archive}: {exc.stderr.strip()}"
        )

    all_text, our_exports, our_members = set(), set(), set()
    # Format: "librustkern.a:member.o:0000000000000000 T symbol"
    line_re = re.compile(r"^[^:]+:([^:]+):[0-9a-fA-F]*\s+(\w)\s+(\S+)$")
    for line in out.split("\n"):
        m = line_re.match(line.strip())
        if not m:
            continue
        member, kind, sym = m.group(1), m.group(2), m.group(3)
        if kind != "T":
            continue
        all_text.add(sym)
        if OUR_MEMBER_RE.match(member):
            our_members.add(member)
            if not MANGLED_RE.match(sym):
                our_exports.add(sym)

    if not our_members:
        # Fail closed. If the crate is renamed or the archive is not what we
        # think it is, "no exports found" must NOT read as "nothing undeclared".
        raise SystemExit(
            f"rust-symbol-gate: ERROR: no rustkern codegen units found in {archive}.\n"
            f"       Expected members matching {OUR_MEMBER_RE.pattern!r}.\n"
            f"       The gate refuses to pass while measuring nothing."
        )
    return all_text, our_exports


def main():
    ap = argparse.ArgumentParser(description="Fail the build if rustkern's FFI surface drifts.")
    ap.add_argument("--archive", default="librustkern.a")
    ap.add_argument("--manifest", default="rust-symbols.manifest")
    ap.add_argument("--nm", default="nm")
    ap.add_argument("--update", action="store_true",
                    help="rewrite the manifest's symbol list from the archive "
                         "(use ONLY when knowingly adding an export; review the diff)")
    args = ap.parse_args()

    manifest = read_manifest(args.manifest)
    all_text, our_exports = nm_archive(args.nm, args.archive)

    if args.update:
        added = sorted(our_exports - set(manifest))
        removed = sorted(set(manifest) - our_exports)
        print(f"rust-symbol-gate: --update: +{len(added)} -{len(removed)}")
        for s in added:
            print(f"  + {s}")
        for s in removed:
            print(f"  - {s}")
        print("rust-symbol-gate: NOT rewriting automatically: rust-symbols.manifest "
              "records OWNERSHIP per symbol, which this tool cannot infer.")
        print("       Edit it by hand, under the right section, and say who owns the symbol.")
        return 0

    missing = sorted(s for s in manifest if s not in all_text)
    undeclared = sorted(our_exports - set(manifest))

    if not missing and not undeclared:
        print(f"rust-symbol-gate: OK - {len(manifest)} declared symbols all exported by "
              f"{args.archive}; no undeclared exports.")
        return 0

    print("=" * 78, file=sys.stderr)
    print("rust-symbol-gate: FAILED - the Rust FFI surface does not match the manifest.",
          file=sys.stderr)
    print("=" * 78, file=sys.stderr)

    if missing:
        print(f"\n{len(missing)} DECLARED SYMBOL(S) NOT EXPORTED by {args.archive}:",
              file=sys.stderr)
        for s in missing:
            print(f"    MISSING  {s}", file=sys.stderr)
        print("\n  A symbol in the manifest is gone from the build. Live C code declares", file=sys.stderr)
        print("  these `extern`; some are only referenced behind a -DRUST_* flag, so the", file=sys.stderr)
        print("  link may NOT catch it. Did an edit, a merge, or a whole-file push drop", file=sys.stderr)
        print("  someone else's subsystem? Check `git`-less history: backups/ and the", file=sys.stderr)
        print("  per-module files under rustkern/. Do NOT 'fix' this by deleting the manifest", file=sys.stderr)
        print("  line unless the removal is deliberate and the C callers are gone too.", file=sys.stderr)

    if undeclared:
        print(f"\n{len(undeclared)} EXPORTED SYMBOL(S) NOT IN {args.manifest}:", file=sys.stderr)
        for s in undeclared:
            print(f"    UNDECLARED  {s}", file=sys.stderr)
        print("\n  A new #[no_mangle] export must be declared in the manifest, under the", file=sys.stderr)
        print("  section for its subsystem, so the manifest cannot silently rot and the", file=sys.stderr)
        print("  next person can see who owns it. Add the line; that is the whole fix.", file=sys.stderr)

    print(file=sys.stderr)
    return 1


if __name__ == "__main__":
    try:
        sys.exit(main())
    except SystemExit as exc:
        if isinstance(exc.code, str):
            print(exc.code, file=sys.stderr)
            sys.exit(2)
        raise
