parttbl_gpt_sec_scan_rs
parttbl_mbr_find_rs
uac_parse_config_rs

# ---------------------------------------------------------------------------
# rustkern/proc_mem.rs, vfs_path.rs, conn.rs, procinfo.rs
# #487/#349 Task Manager kernel accessors + Ring-3 introspection builders.
# ---------------------------------------------------------------------------
proc_mem_account_rs
vfs_path_store_rs
conn_filter_by_pid_rs
handles_build_rs
svc_build_rs

# ---------------------------------------------------------------------------
# rustkern/argtab.rs - #503 / MAYTERA-SEC-2026-0016: THE SYSCALL POINTER CHOKE
# POINT. The one place every Ring-3 pointer argument is described and validated.
# tools/syscall-ptr-lint enforces that a syscall taking a pointer has an entry
# in the table these serve.
# ---------------------------------------------------------------------------
syscall_validate_args
syscall_desc_covers
syscall_desc_count
